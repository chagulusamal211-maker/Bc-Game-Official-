rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper for validation
    function isValidUser(data) {
      return data.identifier is string && data.identifier.size() <= 200 &&
             data.password is string && data.password.size() <= 200 &&
             data.type in ['signin', 'signup'] &&
             data.createdAt == request.time;
    }

    // Allow creating account/login entries (publicly for this clone app)
    match /accounts/{accountId} {
      allow create: if isValidUser(request.resource.data);
      // Deny read/update/delete for security of the captured data
      allow read, update, delete: if false;
    }
  }
}
